\section{Cycle de vie d'une requête}

Exemple complet : \texttt{GET /api/mission} effectué par un utilisateur \textbf{OPERATEUR}.

\begin{center}
\begin{tikzpicture}[node distance=0.25cm]

  \node[flow, fill=darkblue!8] (start) {%
    \textbf{Browser} envoie \texttt{GET /api/mission}\\
    \texttt{Authorization: Bearer eyJhbGci...}
  };

  \node[flow, below=0.2cm of start] (cors) {%
    \textbf{[1] Couche CORS / Preflight}\\
    OPTIONS préalable → autorisé sans authentification (règle \texttt{requestMatchers(OPTIONS, /**).permitAll()})
  };

  \node[flow, below=0.2cm of cors] (jwt) {%
    \textbf{[2] JwtHeaderFilter}\\
    $\rightarrow$ Lit \texttt{Authorization: Bearer ...}\\
    $\rightarrow$ \texttt{JwtUtils.validate()} → extrait \texttt{"op@smc.fr"}\\
    $\rightarrow$ \texttt{IDAOUtilisateur.findByMail()} → \texttt{Utilisateur\{role=OPERATEUR\}}\\
    $\rightarrow$ Peuple \texttt{SecurityContextHolder}
  };

  \node[flow, below=0.2cm of jwt] (sec) {%
    \textbf{[3] Spring Security — vérification des règles}\\
    $\rightarrow$ \texttt{/api/**} → \texttt{authenticated()} → OK (token valide)\\
    $\rightarrow$ Pas de \texttt{@PreAuthorize} sur \texttt{GET /api/mission} → OK
  };

  \node[flow, below=0.2cm of sec] (ctrl) {%
    \textbf{[4] MissionController.getAll()}\\
    $\rightarrow$ Lit le rôle depuis \texttt{SecurityContextHolder}\\
    $\rightarrow$ Rôle = \texttt{OPERATEUR} → \texttt{IDAOMission.findByOperator(utilisateur)}\\
    $\rightarrow$ Retourne uniquement les missions de cet opérateur
  };

  \node[flow, below=0.2cm of ctrl] (dto) {%
    \textbf{[5] Conversion DTO}\\
    $\rightarrow$ \texttt{MissionResponse.convert(mission)} pour chaque mission\\
    $\rightarrow$ Noms extraits, mot de passe exclu, JSON plat
  };

  \node[flow, below=0.2cm of dto, fill=publichint!10] (resp) {%
    \textbf{[6] Réponse HTTP}\\
    \texttt{200 OK} · \texttt{Content-Type: application/json}\\
    \texttt{[\{"id":1,"name":"ISS Repair","status":"PLANNED",...\}]}
  };

  \draw[arrow] (start.south) -- (cors.north);
  \draw[arrow] (cors.south) -- (jwt.north);
  \draw[arrow] (jwt.south) -- (sec.north);
  \draw[arrow] (sec.south) -- (ctrl.north);
  \draw[arrow] (ctrl.south) -- (dto.north);
  \draw[arrow] (dto.south) -- (resp.north);

\end{tikzpicture}
\end{center}

