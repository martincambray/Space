\section{Calcul de trajectoire orbitale}

\subsection{Flux de données}

\begin{center}
\begin{tikzpicture}[node distance=0.25cm]
  \node[flow] (req) {%
    \textbf{1. Requête} \quad \texttt{POST /api/trajectory/\{missionId\}}\\
    Corps : \texttt{\{ altitude: 400, initialSpeed: 7669, spacecraftMass: 20000, celestialBodyId: 3 \}}
  };
  \node[flow, below=0.2cm of req] (load) {%
    \textbf{2. Chargement des entités} (TrajectoryService)\\
    $\rightarrow$ Charge \texttt{Mission} par \texttt{missionId} (404 si absent)\\
    $\rightarrow$ Charge \texttt{CelestialBody} (Terre : M = 5,97×10\textsuperscript{24} kg, R = 6 371 km)\\
    $\rightarrow$ Charge \texttt{Utilisateur} courant (pour l'audit)
  };
  \node[flow, below=0.2cm of load] (calc) {%
    \textbf{3. OrbitalCalculator.compute(altitude, masse, rayon)}\\
    $r = (6371 + 400) \times 1000 = 6\,771\,000$ m\\
    $v = \sqrt{GM/r} \approx 7\,669$ m/s \quad $T = 2\pi\sqrt{r^3/GM} \approx 5\,559$ s\\
    360 points \texttt{[x,y]} = \texttt{[r·cos(θ), r·sin(θ)]} pour θ ∈ [0°, 360°]
  };
  \node[flow, below=0.2cm of calc] (pers) {%
    \textbf{4. Persistance} (TrajectoryService)\\
    $\rightarrow$ \texttt{ObjectMapper.writeValueAsString(result)} → JSON\\
    $\rightarrow$ Sauvegarde \texttt{TrajectoryLog} (audit complet)\\
    $\rightarrow$ Met à jour \texttt{Mission.trajectory} (dernier résultat)
  };
  \node[flow, below=0.2cm of pers] (resp) {%
    \textbf{5. Réponse} \texttt{200 OK} → \texttt{TrajectoryLogResponse}\\
    Contient : vitesse, période, rayon, 360 points de trajectoire
  };
  \draw[arrow] (req.south) -- (load.north);
  \draw[arrow] (load.south) -- (calc.north);
  \draw[arrow] (calc.south) -- (pers.north);
  \draw[arrow] (pers.south) -- (resp.north);
\end{tikzpicture}
\end{center}

\subsection{Formules de mécanique orbitale newtonienne}

\begin{tcolorbox}[mybox, title=Formules clés — OrbitalCalculator.java]
\begin{align}
r &= (R_{\text{planète}} + h) \times 1000 \quad \text{[m]} \\[6pt]
v_{\text{orb}} &= \sqrt{\frac{G \cdot M}{r}} \quad \text{[m/s]} \\[6pt]
T &= 2\pi \sqrt{\frac{r^3}{G \cdot M}} \quad \text{[s]} \\[6pt]
\text{Point}_\theta &= \bigl(r \cos\theta,\; r \sin\theta\bigr) \quad \theta \in \{0°, 1°, \ldots, 359°\}
\end{align}

\medskip
Avec $G = 6{,}674 \times 10^{-11}\ \text{m}^3 \cdot \text{kg}^{-1} \cdot \text{s}^{-2}$ \quad et \quad $M$ = masse du corps céleste (kg)

\medskip
\textbf{Exemple ISS} (Terre, $h = 400$ km) :
$\quad r \approx 6\,771\,000$ m $\quad v \approx 7\,669$ m/s $\quad T \approx 5\,559$ s (92 min)
\end{tcolorbox}

