\begin{center}
\begin{tikzpicture}[node distance=0.25cm]

  \node[flow] (req) {%
    \textbf{1. Requête} \quad \texttt{POST /api/action/\{spacecraftId\}}\\
    Corps JSON : \texttt{\{ "actionType": "CHANGER\_PROPULSION" \}}
  };

  \node[flow, below=0.2cm of req] (check) {%
    \textbf{2. Vérification des capacités} (ActionRegistry)\\
    $\rightarrow$ \texttt{canExecute(TYPE\_ACTION, spacecraft)}\\
    $\rightarrow$ Vérifie dans \texttt{capacities : Map<TYPE\_ACTION, Spacecraft>}\\
    $\rightarrow$ \textcolor{operred}{Si spacecraft non capable → lance \texttt{ActionNotSupportedException} (403)}
  };

  \node[flow, below=0.2cm of check] (exec) {%
    \textbf{3. Exécution de l'action} (ActionRegistry → MoteurPhysique)\\
    $\rightarrow$ \texttt{execute(TYPE\_ACTION, spacecraft)}\\
    $\rightarrow$ Passe l'instance \texttt{Runnable} (*Action) au \texttt{MoteurPhysique}\\
    $\rightarrow$ \texttt{MoteurPhysique.triggerAction(action)} → appelle \texttt{run()}\\
    \quad Exemple : \texttt{ChangerPropulsionAction.run()} modifie le delta\_v
  };

  \node[flow, below=0.2cm of exec] (consomm) {%
    \textbf{4. Mise à jour des consommables} (Spacecraft)\\
    $\rightarrow$ \texttt{spacecraft.updateConsummable(TYPE\_ACTION)}\\
    $\rightarrow$ Déduit la consommation carburant / batterie selon le type d'action
  };

  \node[flow, below=0.2cm of consomm] (orbit) {%
    \textbf{5. Recalcul orbital} (MoteurPhysique)\\
    $\rightarrow$ \texttt{eulerOrbitInit()} — initialisation de l'orbite\\
    $\rightarrow$ \texttt{perturbateOrbit(currentOrbit)} — intégration numérique (Kepler + méthode de Cowell, Euler/RK4)\\
    $\rightarrow$ Retourne l'orbite mise à jour
  };

  \node[flow, below=0.2cm of orbit, fill=publichint!10] (resp) {%
    \textbf{6. Réponse} \quad \texttt{200 OK}\\
    Corps JSON : trajectoire orbitale recalculée
  };

  \draw[arrow] (req.south) -- (check.north);
  \draw[arrow] (check.south) -- (exec.north);
  \draw[arrow] (exec.south) -- (consomm.north);
  \draw[arrow] (consomm.south) -- (orbit.north);
  \draw[arrow] (orbit.south) -- (resp.north);

\end{tikzpicture}
\end{center}

\textbf{Exemple de requête et réponses :}

\begin{multicols}{2}
\textbf{Requête} \texttt{POST /api/action/3} :
